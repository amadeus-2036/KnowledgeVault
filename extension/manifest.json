{
  "manifest_version": 3,
  "name": "Knowledge Vault Clipper",
  "version": "1.0",
  "description": "Frictionless knowledge capture for Knowledge Vault AI",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Knowledge Vault"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
